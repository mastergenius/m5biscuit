def build_pack(defn: dict[str, Any]) -> None:
    pack_id = defn["id"]
    pack_dir = PACKS_DIR / pack_id
    pack_dir.mkdir(parents=True, exist_ok=True)

    concepts = [concept(pack_id, *item) for item in defn["concepts"]]
    concept_ids = [item["id"] for item in concepts]
    rubrics = [rubric(pack_id, "self_check"), rubric(pack_id, "choice_key"), rubric(pack_id, "reflection")]

    e1 = f"{pack_id}.e01"
    e2 = f"{pack_id}.e02"
    e3 = f"{pack_id}.e03"
    e4 = f"{pack_id}.e04"
    e5 = f"{pack_id}.e05"
    e6 = f"{pack_id}.e06"
    episodes = [
        brief(pack_id, 1, "Мини-разбор", concept_ids[:2], defn["brief"], defn["brief_reveal"], e2),
        recall(pack_id, 2, "Восстановить различение", concept_ids[:3], defn["recall_prompt"], defn["recall_reveal"], e3),
        choice(pack_id, 3, "Диагностика похожих вариантов", concept_ids, defn["choice_prompt"], defn["choices"], defn["choice_reveal"], e4),
        apply(pack_id, 4, "Перенос на Biscuit/работу", concept_ids, defn["apply_prompt"], defn["apply_reveal"], e5),
        recall(
            pack_id,
            5,
            "Сжать до правила",
            concept_ids,
            "Сформулируйте одно правило принятия решений по теме pack. Правило должно помогать действовать завтра, а не звучать как лозунг.",
            "Сильное правило содержит объект, действие и критерий. Например: «сначала разделить систему и описание, затем искать наблюдение».",
            e6,
        ),
        apply(
            pack_id,
            6,
            "Следующий эксперимент",
            concept_ids,
            "Назовите один маленький эксперимент на 24 часа, который проверит, что вы действительно поняли тему.",
            "Хороший эксперимент дешевый, наблюдаемый и меняет практику: один лог, один разговор, один чеклист, один рабочий артефакт.",
            None,
        ),
    ]

    manifest = {
        "schema": "biscuit.study-pack.v0",
        "pack_id": pack_id,
        "title": defn["title"],
        "description": defn["description"],
        "revision": "2026-05-24.mim.1",
        "language": "ru",
        "entry_episode_id": e1,
        "generator": {
            "id": "mim-learning-pack-generator",
            "version": "0.1.0",
            "policy": "mac-first-paraphrased-course-themes",
        },
        "files": {"concepts": "concepts.jsonl", "episodes": "episodes.jsonl", "rubrics": "rubrics.jsonl", "assets_dir": "assets"},
        "counts": {"concepts": len(concepts), "episodes": len(episodes), "rubrics": len(rubrics)},
        "constraints": {
            "max_pack_bytes": 524288,
            "max_prompt_chars": 1400,
            "max_reveal_chars": 1800,
            "max_rubric_chars": 1600,
            "max_jsonl_line_bytes": 2200,
        },
        "runtime_targets": ["mac"],
        "sources": [
            {
                "id": f"src.{pack_id}",
                "type": "manual",
                "title": defn["source_title"],
                "citation": defn["source"],
            }
        ],
    }

    write_json(pack_dir / "manifest.json", manifest)
    write_jsonl(pack_dir / "concepts.jsonl", concepts)
    write_jsonl(pack_dir / "episodes.jsonl", episodes)
    write_jsonl(pack_dir / "rubrics.jsonl", rubrics)


def main() -> int:
    for pack in PACKS:
        build_pack(pack)
    print(f"Generated {len(PACKS)} MIM Learning Packs in {PACKS_DIR}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
