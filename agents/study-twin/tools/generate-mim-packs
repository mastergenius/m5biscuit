def rubric(pack_id: str, kind: str = "self_check") -> dict[str, Any]:
    if kind == "choice_key":
        return {
            "id": f"{pack_id}.rubric.choice",
            "kind": "choice_key",
            "criteria": [
                {"id": "criterion.answer", "text": "Выбран вариант, который сохраняет различения курса, а не бытовую эвристику."},
                {"id": "criterion.explain", "text": "После Reveal понятна причина, почему другие варианты слабее."},
            ],
            "actions": SHORT_ACTIONS,
        }
    if kind == "reflection":
        return {
            "id": f"{pack_id}.rubric.reflect",
            "kind": "reflection",
            "criteria": [
                {"id": "criterion.situated", "text": "Ответ привязан к реальному рабочему или личному эпизоду."},
                {"id": "criterion.next", "text": "Есть наблюдаемое следующее действие, а не только красивый вывод."},
            ],
            "actions": SELF_ACTIONS,
        }
    return {
        "id": f"{pack_id}.rubric.self",
        "kind": "self_check",
        "criteria": [
            {"id": "criterion.distinction", "text": "Названо главное различение и его практический смысл."},
            {"id": "criterion.transfer", "text": "Ответ перенесен на конкретную ситуацию, а не повторяет термин."},
            {"id": "criterion.boundary", "text": "Отмечена граница применимости или типичная ошибка."},
        ],
        "actions": SELF_ACTIONS,
    }


def brief(pack_id: str, n: int, title: str, concepts: list[str], prompt: str, reveal: str, next_id: str) -> dict[str, Any]:
    return {
        "id": f"{pack_id}.e{n:02d}",
        "type": "brief",
        "title": title,
        "concept_ids": concepts,
        "objective": "Собрать рабочую рамку перед активным воспроизведением.",
        "prompt": f"Мини-разбор:\n{prompt}",
        "reveal": reveal,
        "rubric_id": f"{pack_id}.rubric.self",
        "response": {"mode": "acknowledge", "actions": ["good", "confused"]},
        "estimated_seconds": 90,
        "next": [next_id],
        "m5paper": {"layout": "text", "full_refresh": True},
    }


def recall(pack_id: str, n: int, title: str, concepts: list[str], prompt: str, reveal: str, next_id: str) -> dict[str, Any]:
    return {
        "id": f"{pack_id}.e{n:02d}",
        "type": "retrieve",
        "title": title,
        "concept_ids": concepts,
        "objective": "Восстановить различение без подсказки и проверить на Reveal.",
        "prompt": prompt,
        "reveal": reveal,
        "rubric_id": f"{pack_id}.rubric.self",
        "response": {"mode": "self_rated", "actions": ["again", "hard", "good", "easy", "confused"]},
        "estimated_seconds": 75,
        "next": [next_id],
        "m5paper": {"layout": "text", "full_refresh": True},
    }


def choice(pack_id: str, n: int, title: str, concepts: list[str], prompt: str, choices: list[str], reveal: str, next_id: str) -> dict[str, Any]:
    return {
        "id": f"{pack_id}.e{n:02d}",
        "type": "diagnostic",
        "title": title,
        "concept_ids": concepts,
        "objective": "Отличить сильную интерпретацию от похожих слабых.",
        "prompt": prompt,
        "reveal": reveal,
        "rubric_id": f"{pack_id}.rubric.choice",
        "response": {
            "mode": "choice",
            "actions": ["answered", "good", "confused"],
            "choices": [{"id": f"choice.{i+1}", "label": label} for i, label in enumerate(choices)],
        },
        "estimated_seconds": 75,
        "next": [next_id],
        "m5paper": {"layout": "choice", "full_refresh": True},
    }


def apply(pack_id: str, n: int, title: str, concepts: list[str], prompt: str, reveal: str, next_id: str | None) -> dict[str, Any]:
    episode = {
        "id": f"{pack_id}.e{n:02d}",
        "type": "apply",
        "title": title,
        "concept_ids": concepts,
        "objective": "Перенести различение на свою рабочую ситуацию.",
        "prompt": prompt,
        "reveal": reveal,
        "rubric_id": f"{pack_id}.rubric.reflect",
        "response": {"mode": "open_ended", "actions": ["again", "hard", "good", "easy", "confused"]},
        "estimated_seconds": 150,
        "m5paper": {"layout": "text", "full_refresh": True},
    }
    if next_id:
        episode["next"] = [next_id]
    return episode


def write_json(path: Path, value: Any) -> None:
    path.write_text(json.dumps(value, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def write_jsonl(path: Path, records: list[dict[str, Any]]) -> None:
    path.write_text(
        "".join(json.dumps(record, ensure_ascii=False, separators=(",", ":")) + "\n" for record in records),
        encoding="utf-8",
    )


def concept(pack_id: str, suffix: str, label: str, summary: str, kind: str = "concept") -> dict[str, Any]:
    return {
        "id": f"{pack_id}.c.{suffix}",
        "label": label,
        "kind": kind,
        "summary": summary,
        "tags": ["mim", "mac-first"],
    }


