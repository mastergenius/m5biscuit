def dump_json(path: Path, value: dict[str, Any]) -> None:
    path.write_text(json.dumps(value, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def dump_jsonl(path: Path, records: list[dict[str, Any]]) -> None:
    path.write_text(
        "".join(json.dumps(record, ensure_ascii=False, separators=(",", ":")) + "\n" for record in records),
        encoding="utf-8",
    )


def concept(pack_id: str, suffix: str, label: str, summary: str, kind: str = "concept") -> dict[str, Any]:
    return {
        "id": f"{pack_id}.c.{suffix}",
        "label": label,
        "kind": kind,
        "summary": summary,
        "tags": ["mim", "selfdev", "guide1"],
    }


