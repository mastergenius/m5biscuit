def build_pack(spec: dict[str, Any]) -> None:
    pack_id = str(spec["id"])
    pack_dir = PACKS_DIR / pack_id
    pack_dir.mkdir(parents=True, exist_ok=True)

    concepts = [concept(pack_id, *item) for item in spec["concepts"]]
    episodes = [
        episode(
            pack_id,
            index,
            item[0],
            item[1],
            item[2],
            item[3],
            item[4],
            item[5],
            item[6] if len(item) > 6 else None,
            item[7] if len(item) > 7 else False,
        )
        for index, item in enumerate(spec["episodes"], start=1)
    ]
    rubrics = [case_rubric(pack_id), signal_rubric(pack_id)]

    dump_json(pack_dir / "manifest.json", pack_manifest(spec, concepts, episodes))
    dump_jsonl(pack_dir / "concepts.jsonl", concepts)
    dump_jsonl(pack_dir / "episodes.jsonl", episodes)
    dump_jsonl(pack_dir / "rubrics.jsonl", rubrics)
    print(f"generated {pack_id}")


def main() -> int:
    for spec in PACKS:
        build_pack(spec)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
