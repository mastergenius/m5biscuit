def episode(
    pack_id: str,
    index: int,
    episode_type: str,
    title: str,
    concept_suffixes: list[str],
    objective: str,
    prompt: str,
    reveal: str,
    choices: list[tuple[str, str]] | None = None,
    final: bool = False,
) -> dict[str, Any]:
    item: dict[str, Any] = {
        "id": f"{pack_id}.e{index:02d}",
        "type": episode_type,
        "title": title,
        "concept_ids": [f"{pack_id}.c.{suffix}" for suffix in concept_suffixes],
        "objective": objective,
        "prompt": prompt,
        "reveal": reveal,
        "rubric_id": f"{pack_id}.rubric.signal" if final else f"{pack_id}.rubric.case",
        "estimated_seconds": 90 if final or choices is None else 120,
        "m5paper": {"layout": "choice" if choices else "text", "full_refresh": True},
    }
    if choices:
        item["response"] = {
            "mode": "choice",
            "actions": ["answered"] if final else ["answered", "good", "unclear", "deeper"],
            "choices": [{"id": choice_id, "label": label} for choice_id, label in choices],
        }
    else:
        item["response"] = {"mode": "acknowledge", "actions": ["good", "unclear", "deeper"]}
    if not final:
        item["next"] = [f"{pack_id}.e{index + 1:02d}"]
    return item


def pack_manifest(pack: dict[str, Any], concepts: list[dict[str, Any]], episodes: list[dict[str, Any]]) -> dict[str, Any]:
