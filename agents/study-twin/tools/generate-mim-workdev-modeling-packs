def build_pack(pack: dict[str, Any]) -> None:
    pack_id = pack["id"]
    concepts = [concept(pack_id, *item) for item in pack["concepts"]]
    rubrics = [case_rubric(pack_id), signal_rubric(pack_id)]
    episodes = [
        episode(pack_id, index, *item)
        for index, item in enumerate(pack["episodes"], start=1)
    ]

    pack_dir = PACKS_DIR / pack_id
    pack_dir.mkdir(parents=True, exist_ok=True)
    dump_json(pack_dir / "manifest.json", pack_manifest(pack, concepts, episodes))
    dump_jsonl(pack_dir / "concepts.jsonl", concepts)
    dump_jsonl(pack_dir / "episodes.jsonl", episodes)
    dump_jsonl(pack_dir / "rubrics.jsonl", rubrics)


def main() -> int:
    for pack in PACKS:
        build_pack(pack)
        print(f"generated {pack['id']}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
