        "schema": "biscuit.study-pack.v0",
        "pack_id": pack["id"],
        "title": pack["title"],
        "description": pack["description"],
        "revision": "2026-05-28.mim.1",
        "language": "ru",
        "entry_episode_id": f"{pack['id']}.e01",
        "generator": {
            "id": "mim-workdev-modeling-generator",
            "version": "2026-05-28",
            "policy": "dense modeling propagation calibration routing",
        },
        "files": {
            "concepts": "concepts.jsonl",
            "episodes": "episodes.jsonl",
            "rubrics": "rubrics.jsonl",
        },
        "counts": {"concepts": len(concepts), "episodes": len(episodes), "rubrics": 2},
        "constraints": {
            "max_prompt_chars": 900,
            "max_reveal_chars": 1200,
            "max_jsonl_line_bytes": 2200,
        },
        "runtime_targets": ["m5paper", "mac"],
        "sources": [SOURCE_MAP[source_key] for source_key in pack["source_keys"]],
    }


