#!/usr/bin/env python3
"""Local web runtime for Biscuit StudyPack v0."""

from __future__ import annotations

import argparse
import json
import mimetypes
import re
import socket
import threading
import time
import urllib.parse
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from typing import Any

TWIN_ROOT = Path(__file__).resolve().parents[1]
DEFAULT_PACKS_DIR = TWIN_ROOT / "examples" / "packs"
DEFAULT_LOG_DIR = TWIN_ROOT / "imports"
WEB_ROOT = TWIN_ROOT / "web-viewer"
ID_RE = re.compile(r"^[a-z0-9][a-z0-9._-]{1,95}$")
REVIEW_ACTIONS = {
    "shown",
    "revealed",
    "answered",
    "again",
    "hard",
    "good",
    "easy",
    "confused",
    "skipped",
    "known",
    "relevant",
    "deeper",
    "unclear",
    "undo",
}


def clean_id(value: Any, label: str) -> str:
    if not isinstance(value, str) or not ID_RE.fullmatch(value):
        raise ValueError(f"{label} must be a valid Biscuit id")
    return value


def clean_non_negative_int(value: Any, label: str) -> int:
    if not isinstance(value, int) or value < 0:
        raise ValueError(f"{label} must be a non-negative integer")
    return value


def clean_score(value: Any, label: str) -> int:
    if not isinstance(value, int) or value < 0 or value > 5:
        raise ValueError(f"{label} must be an integer from 0 to 5")
    return value


class StudyRuntime:
    def __init__(self, packs_dir: Path, log_dir: Path) -> None:
        self.packs_dir = packs_dir
        self.log_dir = log_dir
        self.log_dir.mkdir(parents=True, exist_ok=True)
        self.log_path = self.log_dir / "web_reviews_000001.jsonl"
        self.device_id = f"mac-web-{socket.gethostname().lower().replace('_', '-')[:40]}"
        self.lock = threading.Lock()
        self.next_seq = self._load_next_seq()

    def _load_next_seq(self) -> int:
        max_seq = 0
        if not self.log_path.exists():
            return 1
        with self.log_path.open("r", encoding="utf-8") as fh:
            for line in fh:
                try:
                    value = json.loads(line)
                except json.JSONDecodeError:
                    continue
                seq = value.get("seq")
                if isinstance(seq, int):
                    max_seq = max(max_seq, seq)
        return max_seq + 1

    def list_packs(self) -> list[dict[str, Any]]:
        packs: list[dict[str, Any]] = []
        if not self.packs_dir.exists():
            return packs
        for pack_dir in sorted(self.packs_dir.iterdir()):
            manifest_path = pack_dir / "manifest.json"
            if not manifest_path.exists():
                continue
            try:
                manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
            except (OSError, json.JSONDecodeError):
                continue
            packs.append({
                "id": str(manifest.get("pack_id") or pack_dir.name),
                "title": str(manifest.get("title") or pack_dir.name),
                "revision": str(manifest.get("revision") or ""),
                "description": str(manifest.get("description") or ""),
                "episode_count": int(manifest.get("counts", {}).get("episodes") or 0),
            })
        return packs

    def read_pack(self, pack_id: str) -> dict[str, Any] | None:
        pack_dir = self.packs_dir / pack_id
        try:
            resolved = pack_dir.resolve()
            if self.packs_dir.resolve() not in resolved.parents:
                return None
            manifest = json.loads((pack_dir / "manifest.json").read_text(encoding="utf-8"))
            return {
                "manifest": manifest,
                "concepts_jsonl": (pack_dir / "concepts.jsonl").read_text(encoding="utf-8"),
                "episodes_jsonl": (pack_dir / "episodes.jsonl").read_text(encoding="utf-8"),
                "rubrics_jsonl": (pack_dir / "rubrics.jsonl").read_text(encoding="utf-8"),
            }
        except (OSError, json.JSONDecodeError):
            return None

    def append_review(self, payload: dict[str, Any]) -> dict[str, Any]:
        now_ms = int(time.time() * 1000)
        pack_id = clean_id(payload.get("pack_id"), "pack_id")
        episode_id = clean_id(payload.get("episode_id"), "episode_id")
        session_ms = clean_non_negative_int(payload.get("session_ms"), "session_ms")
        latency_ms = clean_non_negative_int(payload.get("latency_ms"), "latency_ms")
        action = str(payload.get("action") or "")
        if action not in REVIEW_ACTIONS:
            raise ValueError("action is not supported")
        concept_ids_raw = payload.get("concept_ids")
        concept_ids: list[str] = []
        if concept_ids_raw is not None:
            if not isinstance(concept_ids_raw, list):
                raise ValueError("concept_ids must be an array")
            for concept_id in concept_ids_raw:
                clean = clean_id(concept_id, "concept_id")
                if clean not in concept_ids:
                    concept_ids.append(clean)

        with self.lock:
            seq = self.next_seq
            self.next_seq += 1
            event = {
                "schema": "biscuit.review-event.v0",
                "seq": seq,
                "segment": 1,
                "device_id": self.device_id,
                "runtime": "mac",
                "pack_id": pack_id,
                "pack_revision": str(payload.get("pack_revision") or ""),
                "episode_id": episode_id,
                "concept_ids": concept_ids,
                "action": action,
                "session_ms": session_ms,
                "latency_ms": latency_ms,
                "clock": "mac_sync",
                "utc": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime(now_ms / 1000)),
            }
            for key in ("confidence", "effort"):
                value = payload.get(key)
                if value is not None:
                    event[key] = clean_score(value, key)
            response = payload.get("response")
            if isinstance(response, dict):
                clean_response: dict[str, str] = {}
                choice_id = response.get("choice_id")
                if choice_id:
                    clean_response["choice_id"] = clean_id(choice_id, "choice_id")
                for key in ("text", "note"):
                    value = response.get(key)
                    if isinstance(value, str) and value:
                        clean_response[key] = value[:2048]
                if clean_response:
                    event["response"] = clean_response

            with self.log_path.open("a", encoding="utf-8") as fh:
                fh.write(json.dumps(event, ensure_ascii=False, separators=(",", ":")) + "\n")
        return event

    def export_reviews(self) -> bytes:
        if not self.log_path.exists():
            return b""
        return self.log_path.read_bytes()


class Handler(BaseHTTPRequestHandler):
    runtime: StudyRuntime

    def log_message(self, fmt: str, *args: Any) -> None:
        print(f"[study-web] {self.address_string()} {fmt % args}", flush=True)

    def send_json(self, status: int, value: dict[str, Any]) -> None:
        data = json.dumps(value, ensure_ascii=False).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def send_file(self, path: Path) -> None:
        if not path.exists() or not path.is_file():
            self.send_error(404)
            return
        if path.name == "manifest.webmanifest":
            content_type = "application/manifest+json"
        else:
            content_type = mimetypes.guess_type(path.name)[0] or "application/octet-stream"
        data = path.read_bytes()
        self.send_response(200)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def send_bytes(self, status: int, data: bytes, *, content_type: str, filename: str | None = None) -> None:
        self.send_response(status)
        self.send_header("Content-Type", content_type)
        self.send_header("Content-Length", str(len(data)))
        if filename:
            self.send_header("Content-Disposition", f'attachment; filename="{filename}"')
        self.end_headers()
        self.wfile.write(data)

    def read_body_json(self) -> dict[str, Any]:
        length = int(self.headers.get("Content-Length") or "0")
        if length <= 0:
            return {}
        data = self.rfile.read(length)
        value = json.loads(data.decode("utf-8"))
        return value if isinstance(value, dict) else {}

    def do_GET(self) -> None:
        parsed = urllib.parse.urlparse(self.path)
        path = urllib.parse.unquote(parsed.path)
        if path == "/api/packs":
            self.send_json(200, {"packs": self.runtime.list_packs()})
            return
        if path.startswith("/api/packs/"):
            pack_id = path.rsplit("/", 1)[-1]
            pack = self.runtime.read_pack(pack_id)
            if pack is None:
                self.send_json(404, {"error": "pack_not_found"})
                return
            self.send_json(200, pack)
            return
        if path == "/api/status":
            self.send_json(200, {
                "runtime": "mac",
                "device_id": self.runtime.device_id,
                "packs_dir": str(self.runtime.packs_dir),
                "log_path": str(self.runtime.log_path),
                "next_seq": self.runtime.next_seq,
            })
            return
        if path == "/api/reviews/export":
            self.send_bytes(
                200,
                self.runtime.export_reviews(),
                content_type="application/x-ndjson; charset=utf-8",
                filename=self.runtime.log_path.name,
            )
            return

        if path == "/":
            self.send_file(WEB_ROOT / "index.html")
            return
        static_name = path.lstrip("/")
        if "/" not in static_name:
            self.send_file(WEB_ROOT / static_name)
            return
        self.send_error(404)

    def do_POST(self) -> None:
        parsed = urllib.parse.urlparse(self.path)
        if parsed.path != "/api/review":
            self.send_error(404)
            return
        try:
            event = self.runtime.append_review(self.read_body_json())
        except (ValueError, json.JSONDecodeError) as exc:
            self.send_json(400, {"error": "invalid_json", "detail": str(exc)})
            return
        self.send_json(200, {"ok": True, "seq": event["seq"]})


def main() -> int:
    parser = argparse.ArgumentParser(description="Run a local Biscuit StudyPack web viewer.")
    parser.add_argument("--packs-dir", type=Path, default=DEFAULT_PACKS_DIR)
    parser.add_argument("--log-dir", type=Path, default=DEFAULT_LOG_DIR)
    parser.add_argument("--host", default="127.0.0.1")
    parser.add_argument("--port", type=int, default=8765)
    args = parser.parse_args()

    Handler.runtime = StudyRuntime(args.packs_dir, args.log_dir)
    server = ThreadingHTTPServer((args.host, args.port), Handler)
    print(f"Study viewer: http://{args.host}:{args.port}/", flush=True)
    print(f"Packs: {args.packs_dir}", flush=True)
    print(f"Log: {Handler.runtime.log_path}", flush=True)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print()
    finally:
        server.server_close()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
