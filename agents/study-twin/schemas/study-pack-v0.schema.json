{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://biscuit.local/schemas/study-pack-v0.schema.json",
  "title": "Biscuit StudyPack v0",
  "description": "Portable offline-first learning pack generated by the Mac study twin and executed by Biscuit runtimes.",
  "type": "object",
  "required": ["manifest"],
  "properties": {
    "manifest": {
      "$ref": "#/$defs/manifest"
    },
    "concept": {
      "$ref": "#/$defs/concept"
    },
    "episode": {
      "$ref": "#/$defs/episode"
    },
    "rubric": {
      "$ref": "#/$defs/rubric"
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{1,95}$"
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "pack_id",
        "title",
        "revision",
        "generator",
        "files",
        "counts",
        "entry_episode_id",
        "sources"
      ],
      "properties": {
        "schema": {
          "const": "biscuit.study-pack.v0"
        },
        "pack_id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "description": {
          "type": "string",
          "maxLength": 512
        },
        "revision": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "language": {
          "type": "string",
          "maxLength": 16
        },
        "entry_episode_id": {
          "$ref": "#/$defs/id"
        },
        "generator": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "version"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "version": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            "policy": {
              "type": "string",
              "maxLength": 128
            }
          }
        },
        "files": {
          "type": "object",
          "additionalProperties": false,
          "required": ["concepts", "episodes", "rubrics"],
          "properties": {
            "concepts": {
              "const": "concepts.jsonl"
            },
            "episodes": {
              "const": "episodes.jsonl"
            },
            "rubrics": {
              "const": "rubrics.jsonl"
            },
            "assets_dir": {
              "const": "assets"
            }
          }
        },
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["concepts", "episodes", "rubrics"],
          "properties": {
            "concepts": {
              "type": "integer",
              "minimum": 0
            },
            "episodes": {
              "type": "integer",
              "minimum": 0
            },
            "rubrics": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "constraints": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_pack_bytes": {
              "type": "integer",
              "minimum": 1
            },
            "max_prompt_chars": {
              "type": "integer",
              "minimum": 1
            },
            "max_reveal_chars": {
              "type": "integer",
              "minimum": 1
            },
            "max_rubric_chars": {
              "type": "integer",
              "minimum": 1
            },
            "max_jsonl_line_bytes": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "runtime_targets": {
          "type": "array",
          "items": {
            "enum": ["m5paper", "mac"]
          },
          "uniqueItems": true
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/source"
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "title"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "enum": ["manual", "book", "article", "note", "web", "conversation", "other"]
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "url": {
          "type": "string",
          "maxLength": 512
        },
        "citation": {
          "type": "string",
          "maxLength": 512
        }
      }
    },
    "concept": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "kind", "summary"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "kind": {
          "enum": ["concept", "skill", "phrase", "misconception", "source"]
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "prerequisites": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 32
          },
          "uniqueItems": true
        }
      }
    },
    "episode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "title", "concept_ids", "objective", "prompt", "response"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "enum": [
            "brief",
            "retrieve",
            "predict",
            "explain",
            "contrast",
            "apply",
            "map_walk",
            "diagnostic",
            "reflection"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "concept_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "objective": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "prompt": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1200
        },
        "reveal": {
          "type": "string",
          "maxLength": 1600
        },
        "rubric_id": {
          "$ref": "#/$defs/id"
        },
        "response": {
          "$ref": "#/$defs/response"
        },
        "learner_signal": {
          "$ref": "#/$defs/learner_signal"
        },
        "estimated_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 900
        },
        "next": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "m5paper": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "layout": {
              "enum": ["text", "two_panel", "map", "choice"]
            },
            "full_refresh": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "learner_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["signal"],
      "properties": {
        "signal": {
          "enum": [
            "repair",
            "reduce_load",
            "near_transfer",
            "stabilize_then_stretch",
            "increase_transfer",
            "observe",
            "insufficient_evidence"
          ]
        },
        "attempts": {
          "type": "integer",
          "minimum": 0
        },
        "successes": {
          "type": "integer",
          "minimum": 0
        },
        "friction": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "actions"],
      "properties": {
        "mode": {
          "enum": ["acknowledge", "self_rated", "choice", "open_ended", "none"]
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "shown",
              "revealed",
              "answered",
              "again",
              "hard",
              "good",
              "easy",
              "confused",
              "skipped",
              "known",
              "relevant",
              "deeper",
              "unclear"
            ]
          },
          "uniqueItems": true
        },
        "choices": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "label"],
            "properties": {
              "id": {
                "$ref": "#/$defs/id"
              },
              "label": {
                "type": "string",
                "minLength": 1,
                "maxLength": 80
              }
            }
          }
        }
      }
    },
    "rubric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "criteria", "actions"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "enum": ["self_check", "choice_key", "open_ended", "reflection"]
        },
        "criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "text"],
            "properties": {
              "id": {
                "$ref": "#/$defs/id"
              },
              "text": {
                "type": "string",
                "minLength": 1,
                "maxLength": 320
              }
            }
          }
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "label", "meaning"],
            "properties": {
              "id": {
                "enum": ["again", "hard", "good", "easy", "confused", "skipped", "known", "relevant", "deeper", "unclear"]
              },
              "label": {
                "type": "string",
                "minLength": 1,
                "maxLength": 32
              },
              "meaning": {
                "type": "string",
                "minLength": 1,
                "maxLength": 160
              }
            }
          }
        }
      }
    }
  }
}
