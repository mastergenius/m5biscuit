#!/usr/bin/env python3
"""Command-line entry point for the Biscuit FastAPI sync host."""

from __future__ import annotations

import argparse
import os
import subprocess
import sys
from pathlib import Path

from biscuit_sync_common import (
    DEFAULT_PORT,
    SyncHostError,
    add_device,
    create_host,
    default_repo_root,
    default_root,
    ensure_dirs,
    load_bootstrap,
    load_host,
    load_paired,
    maybe_start_mdns,
    set_bootstrap_secret,
    write_firmware_bootstrap_fallback,
)


def cmd_init(args: argparse.Namespace) -> None:
    root = args.root.resolve()
    host = create_host(root, host_name=args.host_name, port=args.port, force=args.force)
    print(f"initialized {host['host_name']} ({host['host_id']}) at {root}")


def cmd_add_device(args: argparse.Namespace) -> None:
    root = args.root.resolve()
    secret = add_device(root, args.device_id, name=args.name, secret=args.secret)
    print(f"paired device {args.device_id}")
    print(f"dev secret: {secret}")


def cmd_set_bootstrap_secret(args: argparse.Namespace) -> None:
    root = args.root.resolve()
    secret = set_bootstrap_secret(root, secret=args.secret)
    print("bootstrap pairing enabled")
    print(f"bootstrap secret: {secret}")


def cmd_write_firmware_bootstrap(args: argparse.Namespace) -> None:
    root = args.root.resolve()
    repo_root = args.repo_root.resolve()
    path = write_firmware_bootstrap_fallback(
        root,
        repo_root=repo_root,
        host_url=args.host_url,
        device_id=args.device_id,
    )
    print(f"wrote firmware bootstrap fallback: {path}")
    print("secret copied from local device-sync config; file is git-ignored")


def cmd_status(args: argparse.Namespace) -> None:
    root = args.root.resolve()
    host = load_host(root)
    paired = load_paired(root)
    bootstrap = load_bootstrap(root)
    devices = paired.get("devices", {})
    print(f"host: {host.get('host_name')} ({host.get('host_id')})")
    print(f"root: {root}")
    print(f"paired devices: {len(devices) if isinstance(devices, dict) else 0}")
    print(f"bootstrap pairing: {'enabled' if bootstrap.get('enabled') and bootstrap.get('secret') else 'disabled'}")
    print(f"inbox: {root / 'inbox'}")


def cmd_serve(args: argparse.Namespace) -> None:
    root = args.root.resolve()
    ensure_dirs(root)
    host = load_host(root)

    try:
        import uvicorn
    except ImportError as exc:
        raise SyncHostError(
            "FastAPI server dependencies are missing; run "
            "agents/device-sync/dev-server or "
            "uv run --project agents/device-sync python agents/device-sync/biscuit-sync serve"
        ) from exc

    app_dir = str(default_root())
    if app_dir not in sys.path:
        sys.path.insert(0, app_dir)
    current_pythonpath = os.environ.get("PYTHONPATH")
    os.environ["PYTHONPATH"] = app_dir if not current_pythonpath else app_dir + os.pathsep + current_pythonpath
    os.environ["BISCUIT_SYNC_ROOT"] = str(root)
    os.environ["BISCUIT_SYNC_DEBUG"] = "1" if args.debug else "0"

    mdns = maybe_start_mdns(host, args.port, args.advertise)
    print(f"serving {host['host_name']} ({host['host_id']}) on http://{args.host}:{args.port}")
    if args.advertise:
        print("advertising _biscuit-sync._tcp.local" if mdns else "mDNS advertisement unavailable")
    try:
        uvicorn.run(
            "biscuit_sync_app:create_app",
            factory=True,
            host=args.host,
            port=args.port,
            reload=args.reload,
            reload_dirs=[app_dir] if args.reload else None,
            log_level="debug" if args.debug else "info",
        )
    finally:
        if mdns:
            mdns.terminate()
            try:
                mdns.wait(timeout=2)
            except subprocess.TimeoutExpired:
                mdns.kill()


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Run a local Biscuit device sync host.")
    parser.add_argument("--root", type=Path, default=default_root(), help="device-sync root directory")
    sub = parser.add_subparsers(dest="command", required=True)

    init = sub.add_parser("init", help="initialize local host identity")
    init.add_argument("--host-name", default=None)
    init.add_argument("--port", type=int, default=DEFAULT_PORT)
    init.add_argument("--force", action="store_true")

    add = sub.add_parser("add-device", help="add a development paired device secret")
    add.add_argument("device_id")
    add.add_argument("--name", default=None)
    add.add_argument("--secret", default=None, help="32-byte hex secret; generated if omitted")

    bootstrap = sub.add_parser("set-bootstrap-secret", help="set the temporary firmware bootstrap secret")
    bootstrap.add_argument("--secret", default=None, help="32-byte hex secret; generated if omitted")

    fw = sub.add_parser("write-firmware-bootstrap", help="write the ignored firmware-local bootstrap fallback")
    fw.add_argument("--host-url", default=None, help="bootstrap server URL; preserves existing local value if omitted")
    fw.add_argument("--device-id", default=None, help="device id; preserves existing local value if omitted")
    fw.add_argument("--repo-root", type=Path, default=default_repo_root())

    sub.add_parser("status", help="show local host status")

    serve = sub.add_parser("serve", help="run the sync host FastAPI daemon")
    serve.add_argument("--host", default="127.0.0.1")
    serve.add_argument("--port", type=int, default=DEFAULT_PORT)
    serve.add_argument("--advertise", action="store_true", help="advertise with macOS dns-sd if available")
    serve.add_argument("--debug", action="store_true", help="log request/response metadata without secrets")
    serve.add_argument("--reload", action="store_true", help="enable uvicorn hot reload for server development")
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        if args.command == "init":
            cmd_init(args)
        elif args.command == "add-device":
            cmd_add_device(args)
        elif args.command == "set-bootstrap-secret":
            cmd_set_bootstrap_secret(args)
        elif args.command == "write-firmware-bootstrap":
            cmd_write_firmware_bootstrap(args)
        elif args.command == "status":
            cmd_status(args)
        elif args.command == "serve":
            cmd_serve(args)
        else:
            parser.error(f"unknown command: {args.command}")
    except SyncHostError as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 2
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
